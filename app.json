{
  "expo": {
    "name": "YEF Tracker",
    "slug": "yef-evangelism-tracker",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1e3a5f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yef.tracker",
      "infoPlist": {
        "NSCameraUsageDescription": "YEF Tracker uses the camera to take photos for student profiles.",
        "NSPhotoLibraryUsageDescription": "YEF Tracker accesses your photos for profile pictures."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1e3a5f"
      },
      "package": "com.yef.tracker",
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "YEF Tracker accesses your photos for profile pictures."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "yeftracker"
  }
}
